# ---- InfraMind environment ----
# Copy to .env and adjust. All values have working defaults for local dev.

# Postgres
POSTGRES_USER=inframind
POSTGRES_PASSWORD=inframind
POSTGRES_DB=inframind

# Database / Cache (overridden by docker-compose for container networking)
DATABASE_URL=postgresql+psycopg://inframind:inframind@localhost:5432/inframind
REDIS_URL=redis://localhost:6379/0

# Vector store
CHROMA_PERSIST_DIR=./.data/chroma

# ---- AI providers ----
# Choose the default provider: openai | gemini | ollama | mock
AI_PROVIDER=mock

# OpenAI (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Gemini (optional)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Ollama (optional, fully local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Embeddings: sentence-transformers (local, default) | openai
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ---- Email reporting (optional, uses console backend if unset) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=inframind@localhost
REPORT_RECIPIENTS=ops@example.com

# ---- Connectors ----
# Comma-separated list of enabled connectors
ENABLED_CONNECTORS=azure,aws,gcp,kubernetes,github

# Per-connector data mode: mock (bundled sample data, default) | live (real cloud APIs).
# The Setup page can override these at runtime. Live mode needs requirements-cloud.txt.
AZURE_MODE=mock
AWS_MODE=mock
GCP_MODE=mock
KUBERNETES_MODE=mock
GITHUB_MODE=mock

# ---- Azure live credentials (only needed when AZURE_MODE=live) ----
# Subscription is required. Leave the service-principal fields blank to use `az login`
# / managed identity via DefaultAzureCredential.
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ---- AWS live credentials (only needed when AWS_MODE=live) ----
# Leave keys blank to use a shared profile / env vars / instance role (boto3 default chain).
AWS_REGION=us-east-1
AWS_PROFILE=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# ---- App ----
ENV=development
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production
